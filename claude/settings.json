{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(date *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(mkdir -p docs/claude)",
      "Bash(test -d *)",
      "Bash(test -f *)",
      "Bash(which *)",
      "Bash(aws * describe-*)",
      "Bash(aws * get-*)",
      "Bash(aws * list-*)",
      "Bash(docker compose *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git checkout *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git pull *)",
      "Bash(git show *)",
      "Bash(git show)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git switch *)",
      "Bash(go build *)",
      "Bash(go get *)",
      "Bash(go mod tidy)",
      "Bash(go vet *)",
      "Bash(rspec *)",
      "Bash(mise x -- rspec *)",
      "Bash(bundle exec rspec *)",
      "Bash(mise x -- bundle exec rspec *)",
      "Bash(rails test)",
      "Bash(mise x -- rails test)",
      "Bash(bundle exec rails test)",
      "Bash(mise x -- bundle exec rails test)",
      "Bash(rails test:*)",
      "Bash(mise x -- rails test:*)",
      "Bash(bundle exec rails test:*)",
      "Bash(mise x -- bundle exec rails test:*)",
      "Bash(rails data:*)",
      "Bash(mise x -- rails data:*)",
      "Bash(bundle exec rails data:*)",
      "Bash(mise x -- bundle exec rails data:*)",
      "Bash(rails assets:*)",
      "Bash(mise x -- rails assets:*)",
      "Bash(bundle exec rails assets:*)",
      "Bash(mise x -- bundle exec rails assets:*)",
      "Bash(rails db:*)",
      "Bash(mise x -- rails db:*)",
      "Bash(bundle exec rails db:*)",
      "Bash(mise x -- bundle exec rails db:*)",
      "Bash(rails spec)",
      "Bash(mise x -- rails spec)",
      "Bash(bundle exec rails spec)",
      "Bash(mise x -- bundle exec rails spec)",
      "Bash(rails spec:*)",
      "Bash(mise x -- rails spec:*)",
      "Bash(bundle exec rails spec:*)",
      "Bash(mise x -- bundle exec rails spec:*)",
      "Bash(rubocop *)",
      "Bash(mise x -- rubocop *)",
      "Bash(bundle exec rubocop *)",
      "Bash(mise x -- bundle exec rubocop *)",
      "Bash(black *)",
      "Bash(mypy *)",
      "Bash(pip list *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(ruff *)",
      "Bash(terraform fmt *)",
      "Bash(terraform init *)",
      "Bash(terraform plan *)",
      "Bash(terraform show *)",
      "Bash(terraform validate *)",
      "Search",
      "Task(Explore)",
      "Task(Plan)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(aws * delete-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws ec2 terminate-instances *)",
      "Bash(git clean -f *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(make apply)",
      "Bash(make deploy*)",
      "Bash(make push*)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(terraform apply)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Read(**/.aws/credentials)",
      "Read(**/credentials*)",
      "Read(*.secrets.*)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git clean *)",
      "Bash(git commit *)",
      "Read(*.env)",
      "Read(*.env.*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "lua-lsp@claude-plugins-official": true,
    "ruby-skills@ruby-skills": true,
    "ruby-lsp@ruby-skills": true,
    "astral@astral-sh": true,
    "bash-language-server@claude-code-lsps": true,
    "terraform-ls@claude-code-lsps": true
  },
  "model": "opus"
}
