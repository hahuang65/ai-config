{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "formatter": {
    "rubocop": {
      "disabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "file *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "brew --cache *": "allow",
      "brew cat *": "allow",
      "brew list": "allow",
      "brew list *": "allow",
      "brew info *": "allow",
      "npm list": "allow",
      "npm list *": "allow",
      "date *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "mkdir -p docs/claude": "allow",
      "mkdir -p docs/claude/*": "allow",
      "mkdir -p */docs/claude": "allow",
      "mkdir -p */docs/claude/*": "allow",
      "echo *": "allow",
      "open */docs/claude/*.html": "allow",
      "open docs/claude/*.html": "allow",
      "test -d *": "allow",
      "test -f *": "allow",
      "which *": "allow",
      "aws * describe-*": "allow",
      "aws * get-*": "allow",
      "aws * list-*": "allow",
      "docker compose *": "allow",
      "git branch *": "allow",
      "git branch": "allow",
      "git checkout *": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git fetch *": "allow",
      "git log *": "allow",
      "git log": "allow",
      "git pull *": "allow",
      "git show *": "allow",
      "git show": "allow",
      "git stash *": "allow",
      "git status *": "allow",
      "git status": "allow",
      "git switch *": "allow",
      "go build *": "allow",
      "go get *": "allow",
      "go mod tidy": "allow",
      "go vet *": "allow",
      "rspec *": "allow",
      "mise x -- rspec *": "allow",
      "bundle exec rspec *": "allow",
      "mise x -- bundle exec rspec *": "allow",
      "rails test": "allow",
      "mise x -- rails test": "allow",
      "bundle exec rails test": "allow",
      "mise x -- bundle exec rails test": "allow",
      "rails test:*": "allow",
      "mise x -- rails test:*": "allow",
      "bundle exec rails test:*": "allow",
      "mise x -- bundle exec rails test:*": "allow",
      "rails data:*": "allow",
      "mise x -- rails data:*": "allow",
      "bundle exec rails data:*": "allow",
      "mise x -- bundle exec rails data:*": "allow",
      "rails assets:*": "allow",
      "mise x -- rails assets:*": "allow",
      "bundle exec rails assets:*": "allow",
      "mise x -- bundle exec rails assets:*": "allow",
      "rails db:*": "allow",
      "mise x -- rails db:*": "allow",
      "bundle exec rails db:*": "allow",
      "mise x -- bundle exec rails db:*": "allow",
      "rails spec": "allow",
      "mise x -- rails spec": "allow",
      "bundle exec rails spec": "allow",
      "mise x -- bundle exec rails spec": "allow",
      "rails spec:*": "allow",
      "mise x -- rails spec:*": "allow",
      "bundle exec rails spec:*": "allow",
      "mise x -- bundle exec rails spec:*": "allow",
      "rubocop *": "allow",
      "mise x -- rubocop *": "allow",
      "bundle exec rubocop *": "allow",
      "mise x -- bundle exec rubocop *": "allow",
      "black *": "allow",
      "mypy *": "allow",
      "pip list *": "allow",
      "pytest *": "allow",
      "python -m pytest *": "allow",
      "ruff *": "allow",
      "terraform fmt *": "allow",
      "terraform init *": "allow",
      "terraform plan *": "allow",
      "terraform show *": "allow",
      "terraform validate *": "allow",
      "aws * delete-*": "deny",
      "aws * terminate-*": "deny",
      "aws ec2 terminate-instances *": "deny",
      "git clean -f *": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "deny",
      "make apply": "deny",
      "make deploy*": "deny",
      "make push*": "deny",
      "rm *": "deny",
      "rm -rf *": "deny",
      "echo *>*": "deny",
      "echo *>>*": "deny",
      "terraform apply": "deny",
      "terraform apply *": "deny",
      "terraform destroy *": "deny",
      "git add *": "ask",
      "git clean *": "ask",
      "git commit *": "ask"
    },
    "read": {
      "*": "allow",
      "*/.claude/*": "allow",
      "*/.config/opencode/*": "allow",
      "~/.claude/*": "allow",
      "~/.claude/skills/**": "allow",
      "**/.aws/credentials": "deny",
      "**/credentials*": "deny",
      "*.secrets.*": "deny",
      "*.env": "ask",
      "*.env.*": "ask"
    },
    "write": {
      "*": "ask",
      "docs/claude/*": "allow",
      "*/docs/claude/*": "allow"
    },
    "edit": {
      "*": "ask",
      "docs/claude/*": "allow",
      "*/docs/claude/*": "allow"
    },
    "task": {
      "*": "ask",
      "explore": "allow",
      "plan": "allow"
    },
    "glob": "allow",
    "glob *": "allow",
    "grep": "allow",
    "grep *": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
